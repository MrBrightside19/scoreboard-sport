VITE_SUPABASE_URL=https://TU_PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_CLAVE_ANON_O_PUBLISHABLE

# Intervalo (ms) de actualización del reloj en vivo: mesa de control → Supabase → overlay/OBS/live.
# Mínimo: 1000. Por defecto: 5000.
VITE_LIVE_CLOCK_UPDATE_MS=5000

# Alias heredado; se usa solo si VITE_LIVE_CLOCK_UPDATE_MS no está definida.
VITE_POLL_INTERVAL_MS=5000

VITE_TOURNAMENT_TABLE_REFRESH_MS=60000
